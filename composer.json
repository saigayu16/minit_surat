{
    "name": "projek/minit-surat",
    "description": "Email sender for Minit Surat",
    "type": "project",
    "require": {
        "php": ">=8.1.0",
        "sendinblue/api-v3-sdk": "^3.5",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
